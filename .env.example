# ================================================================
# .env.example — Copy to .env and fill in your values
# ================================================================

# ----------------------------------------------------------------
# LLM Provider
# Options: "groq" | "google" | "ollama"
# ----------------------------------------------------------------
LLM_PROVIDER=groq

# Groq (free tier — get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (free tier — get key at https://aistudio.google.com)
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-1.5-flash

# Ollama (fully local — no API key needed)
# Ensure Ollama is running: https://ollama.com
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ----------------------------------------------------------------
# PostgreSQL — Long-Term Memory (LTM)
# Must match docker-compose.yml postgres service credentials
# ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_AGENT_DB=agent_memory

# ----------------------------------------------------------------
# Redis — Short-Term Memory (STM)
# Must match docker-compose.yml redis service credentials
# ----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0
SESSION_TTL=3600

# ----------------------------------------------------------------
# Langfuse Observability
# After starting Docker, go to http://localhost:3000
# Create an account → Create a project → Copy API keys below
# ----------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=http://localhost:3000
